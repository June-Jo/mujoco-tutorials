<?xml version="1.0" encoding="utf-8"?>
<!--
  Doosan Robotics M1013 - MuJoCo MJCF
  Kinematic chain from: DoosanRobotics/doosan-robot2 (humble branch)
  Visual meshes: dsr_description2/meshes/m1013_white/

  Joint origins (URDF):
    joint1: xyz="0 0 0.1525"      rpy="0 0 0"
    joint2: xyz="0 0.0345 0"      rpy="0 -1.571 -1.571"
    joint3: xyz="0.62 0 0"        rpy="0 0 1.571"
    joint4: xyz="0 -0.559 0"      rpy="1.571 0 0"
    joint5: xyz="0 0 0"           rpy="-1.571 0 0"
    joint6: xyz="0 -0.121 0"      rpy="1.571 0 0"
    tool0:  xyz="0 0 0"           rpy="3.14159 -1.5708 0"

  All joint axes = (0,0,1) in child body frame.
  Body quaternions derived from URDF rpy (extrinsic XYZ = Rz*Ry*Rx).
-->
<mujoco model="doosan_m1013">

  <compiler angle="radian" autolimits="true" meshdir="meshes/m1013_stl"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.4 0.6 0.8" rgb2="0.05 0.05 0.05" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.2 0.2" rgb2="0.1 0.1 0.1" markrgb="0.6 0.6 0.6"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="4 4" reflectance="0.1"/>
    <material name="target_mat" rgba="1.0 0.2 0.2 0.7"/>
    <material name="ee_mat"     rgba="0.1 0.9 0.1 1.0"/>

    <!-- M1013 White meshes (URDF scale=0.001) -->
    <mesh name="base_mesh"   file="MF1013_0_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link1_mesh"  file="MF1013_1_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link2_mesh0" file="MF1013_2_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link2_mesh1" file="MF1013_2_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link2_mesh2" file="MF1013_2_2.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link3_mesh"  file="MF1013_3_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link4_mesh0" file="MF1013_4_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link4_mesh1" file="MF1013_4_1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link5_mesh"  file="MF1013_5_0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="link6_mesh"  file="MF1013_6_0.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" rgba="0 0 0 0"/>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>

    <!-- Target marker (mocap: 물리 영향 없이 위치 직접 지정) -->
    <body name="target" pos="0.5 0.0 1.0" mocap="true">
      <geom name="target_geom" type="sphere" size="0.035"
            material="target_mat" contype="0" conaffinity="0"/>
    </body>

    <!-- ── Base (URDF: base_link-base fixed joint at z=0.450) ── -->
    <body name="base_link" pos="0 0 0">
      <geom name="base_geom" type="mesh" mesh="base_mesh" contype="0" conaffinity="0"/>
      <!-- collision geoms disabled (no self-collision needed for RL) -->
      <geom name="base_col" type="cylinder" size="0.105 0.225" pos="0 0 0.225"
            contype="0" conaffinity="0" rgba="0 0 0 0"/>

      <!-- ── Link 1 ── joint1: xyz="0 0 0.1525" rpy="0 0 0" ── -->
      <body name="link1" pos="0 0 0.1525" quat="1 0 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1"
               range="-6.2832 6.2832" damping="5.0" armature="0.4"/>
        <geom name="link1_geom" type="mesh" mesh="link1_mesh" contype="0" conaffinity="0"/>
        <geom name="link1_col" type="cylinder" size="0.09 0.17" pos="0 0 0.12"
              contype="0" conaffinity="0" rgba="0 0 0 0"/>

        <!-- ── Link 2 ── joint2: xyz="0 0.0345 0" rpy="0 -pi/2 -pi/2" ── -->
        <!-- quat from Rz(-pi/2)*Ry(-pi/2)*Rx(0) = (0.5, -0.5, -0.5, -0.5)  -->
        <body name="link2" pos="0 0.0345 0" quat="0.5 -0.5 -0.5 -0.5">
          <joint name="joint2" type="hinge" axis="0 0 1"
                 range="-6.2832 6.2832" damping="5.0" armature="0.4"/>
          <geom name="link2_geom0" type="mesh" mesh="link2_mesh0" contype="0" conaffinity="0"/>
          <geom name="link2_geom1" type="mesh" mesh="link2_mesh1" contype="0" conaffinity="0"/>
          <geom name="link2_geom2" type="mesh" mesh="link2_mesh2" contype="0" conaffinity="0"/>
          <!-- upper arm collision capsule (local X dir, 0→0.62m) -->
          <geom name="link2_col" type="capsule" fromto="0.05 0 0 0.57 0 0" size="0.06"
                contype="0" conaffinity="0" rgba="0 0 0 0"/>

          <!-- ── Link 3 ── joint3: xyz="0.62 0 0" rpy="0 0 pi/2" ── -->
          <!-- quat from Rz(pi/2)*Ry(0)*Rx(0) = (0.7071, 0, 0, 0.7071)     -->
          <body name="link3" pos="0.62 0 0" quat="0.7071 0 0 0.7071">
            <joint name="joint3" type="hinge" axis="0 0 1"
                   range="-2.7925 2.7925" damping="3.0" armature="0.3"/>
            <geom name="link3_geom" type="mesh" mesh="link3_mesh" contype="0" conaffinity="0"/>
            <!-- forearm collision capsule (local -Y dir, 0→-0.559m) -->
            <geom name="link3_col" type="capsule" fromto="0 -0.05 0 0 -0.51 0" size="0.055"
                  contype="0" conaffinity="0" rgba="0 0 0 0"/>

            <!-- ── Link 4 ── joint4: xyz="0 -0.559 0" rpy="pi/2 0 0" ── -->
            <!-- quat from Rz(0)*Ry(0)*Rx(pi/2) = (0.7071, 0.7071, 0, 0)   -->
            <body name="link4" pos="0 -0.559 0" quat="0.7071 0.7071 0 0">
              <joint name="joint4" type="hinge" axis="0 0 1"
                     range="-6.2832 6.2832" damping="1.5" armature="0.1"/>
              <geom name="link4_geom0" type="mesh" mesh="link4_mesh0" contype="0" conaffinity="0"/>
              <geom name="link4_geom1" type="mesh" mesh="link4_mesh1" contype="0" conaffinity="0"/>
              <geom name="link4_col" type="sphere" size="0.06"
                    contype="0" conaffinity="0" rgba="0 0 0 0"/>

              <!-- ── Link 5 ── joint5: xyz="0 0 0" rpy="-pi/2 0 0" ── -->
              <!-- quat from Rz(0)*Ry(0)*Rx(-pi/2) = (0.7071, -0.7071, 0, 0) -->
              <body name="link5" pos="0 0 0" quat="0.7071 -0.7071 0 0">
                <joint name="joint5" type="hinge" axis="0 0 1"
                       range="-6.2832 6.2832" damping="1.5" armature="0.1"/>
                <geom name="link5_geom" type="mesh" mesh="link5_mesh" contype="0" conaffinity="0"/>
                <geom name="link5_col" type="capsule" fromto="0 0 0 0 -0.11 0" size="0.04"
                      contype="0" conaffinity="0" rgba="0 0 0 0"/>

                <!-- ── Link 6 ── joint6: xyz="0 -0.121 0" rpy="pi/2 0 0" ── -->
                <!-- quat from Rz(0)*Ry(0)*Rx(pi/2) = (0.7071, 0.7071, 0, 0)  -->
                <body name="link6" pos="0 -0.121 0" quat="0.7071 0.7071 0 0">
                  <joint name="joint6" type="hinge" axis="0 0 1"
                         range="-6.2832 6.2832" damping="0.8" armature="0.05"/>
                  <geom name="link6_geom" type="mesh" mesh="link6_mesh" contype="0" conaffinity="0"/>
                  <geom name="link6_col" type="cylinder" size="0.04 0.03"
                        contype="0" conaffinity="0" rgba="0 0 0 0"/>

                  <!-- TCP (tool0): rpy="pi -pi/2 0" → just a site for EE tracking -->
                  <site name="ee_site" pos="0 0 0" size="0.015" rgba="0.1 0.9 0.1 1"/>
                  <geom name="ee_marker" type="sphere" size="0.018"
                        pos="0 0 0" material="ee_mat" contype="0" conaffinity="0"/>

                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Position actuators: ctrl = target angle, PD control internally -->
  <!-- kp 낮춤 (부드러운 응답), kv 높임 (진동 억제 & 감속) -->
  <actuator>
    <position name="act1" joint="joint1" kp="500"  kv="100" ctrlrange="-6.2832 6.2832"/>
    <position name="act2" joint="joint2" kp="700"  kv="140" ctrlrange="-6.2832 6.2832"/>
    <position name="act3" joint="joint3" kp="500"  kv="100" ctrlrange="-2.7925 2.7925"/>
    <position name="act4" joint="joint4" kp="200"  kv="50"  ctrlrange="-6.2832 6.2832"/>
    <position name="act5" joint="joint5" kp="200"  kv="50"  ctrlrange="-6.2832 6.2832"/>
    <position name="act6" joint="joint6" kp="70"   kv="20"  ctrlrange="-6.2832 6.2832"/>
  </actuator>

</mujoco>
